{
  "name": "level-up",
  "displayName": "Level Up: Gamified Coding",
  "description": "Earn XP, unlock achievements, and level up as you code in VS Code.",
  "version": "0.0.3",
  "publisher": "Pocky",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "xp",
    "levels",
    "achievements",
    "gamification",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/level-up.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/PckyDev/LevelUp.git"
  },
  "homepage": "https://github.com/PckyDev/LevelUp#readme",
  "bugs": {
    "url": "https://github.com/PckyDev/LevelUp/issues"
  },
  "contributes": {
    "commands": [
      {
        "command": "levelUp.openDashboard",
        "title": "Level Up: Open Dashboard"
      },
      {
        "command": "levelUp.showSummary",
        "title": "Level Up: Show Summary"
      },
      {
        "command": "levelUp.resetProgress",
        "title": "Level Up: Reset Progress"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "levelUp",
          "title": "Level Up",
          "icon": "media/level-up-activity.svg"
        }
      ]
    },
    "views": {
      "levelUp": [
        {
          "id": "levelUp.dashboard",
          "name": "Dashboard",
          "type": "webview",
          "icon": "media/level-up-activity.svg"
        }
      ]
    },
    "configuration": {
      "title": "Level Up",
      "properties": {
        "levelUp.effects.editorCelebrations": {
          "type": "boolean",
          "default": true,
          "description": "Show editor confetti bursts when you level up or unlock achievements."
        },
        "levelUp.effects.reducedMotion": {
          "type": "boolean",
          "default": false,
          "description": "Use lighter, shorter editor celebration effects with less motion."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.6.3"
  }
}
